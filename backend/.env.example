# Local development only — do NOT commit .env or paste secrets in chat.
# On Vercel: Project → Settings → Environment variables (all services share them).

PORT=5000
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
FRONTEND_URL=http://localhost:3000

# Vercel production (set in dashboard, NOT localhost):
# FRONTEND_URL=https://your-app.vercel.app
# (If omitted on Vercel, the app auto-detects from VERCEL_URL)

# Optional — AI chat / SOP review only:
# OLLAMA_HOST=https://api.ollama.com
# OLLAMA_API_KEY=your_key
# OLLAMA_MODEL=gemma4:31b

# Not used by auth (Supabase handles JWTs) — safe to omit on Vercel:
# JWT_SECRET=
